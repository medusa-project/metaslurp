%div
  %h1.sr-only University Library, University of Illinois at Urbana-Champaign
  .d-flex.justify-content-between.align-items-center{style: 'padding: 0 10px; height: 48px;'}
    %a.navbar-brand{href: "https://www.library.illinois.edu", style: 'padding: 0; margin: 0; display: flex; align-items: center; height: 100%; overflow: hidden;'}
      = image_tag 'UpdatedHeader.png',
                   class: 'banner-image-library',
                   alt: 'University of Illinois Library',
                   style: 'height: 90px; width: auto;'
    .user-actions
      - if current_user
        .btn-group{role: "group"}
          %button#user-dropdown.btn.btn-sm.btn-default.dropdown-toggle{"aria-expanded": "false",
                                                                       "aria-haspopup": "true",
                                                                       "data-toggle": "dropdown",
                                                                       type: "button"}
            = icon_for(current_user)
            = current_user.username
          .dropdown-menu.dropdown-menu-right{"aria-labelledby": "user-dropdown"}
            = link_to 'Administration', admin_root_path, class: 'dropdown-item'
            = link_to 'Log Out', signout_path, method: :delete, class: 'dropdown-item'
      - else
        = link_to 'Staff Login', signin_path, method: :post, class: 'stripe-link'